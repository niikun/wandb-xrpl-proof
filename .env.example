# XRPL ウォレットシード (テストネット用: s で始まるシード)
# 本番では安全な custody サービスを使用すること
XRPL_WALLET_SEED=sYourXRPLWalletSeedHere

# XRPL ノード URL (デフォルト: テストネット)
XRPL_NODE_URL=https://s.altnet.rippletest.net:51234

# W&B API キー
WANDB_API_KEY=your_wandb_api_key_here

# IPFS アップロード用 API URL (オプション, use_ipfs=True の場合のみ必要)
# Kubo 互換 HTTP API。ipfs daemon が必要。
# IPFS_API_URL=http://127.0.0.1:5001

# IPFS 取得用ゲートウェイ URL (オプション)
# アップロードとフェッチは用途・可用性が異なるため別々に設定できます。
# 選択肢: ローカル (要 ipfs daemon) / Cloudflare / Pinning サービス独自 gateway
# IPFS_GATEWAY_URL=http://127.0.0.1:8080/ipfs
# IPFS_GATEWAY_URL=https://cloudflare-ipfs.com/ipfs
# IPFS_GATEWAY_URL=https://<your-gateway>.mypinata.cloud/ipfs
