# XRPL ウォレットシード (テストネット用: s で始まるシード)
# 本番では安全な custody サービスを使用すること
XRPL_WALLET_SEED=sYourXRPLWalletSeedHere

# XRPL ノード URL (デフォルト: テストネット)
XRPL_NODE_URL=https://s.altnet.rippletest.net:51234

# W&B API キー
WANDB_API_KEY=your_wandb_api_key_here

# IPFS API URL (オプション, use_ipfs=True の場合のみ必要)
# IPFS_API_URL=http://127.0.0.1:5001
